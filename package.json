{
  "name": "hariknows-workspace",
  "private": true,
  "scripts": {
    "setup": "npm install && npm run install:frontends && dotnet restore backend/HariKnowsBackend.sln",
    "install:frontends": "npm install --prefix frontend_helpdesk && npm install --prefix frontend_registrar",
    "dev": "concurrently -k -n backend,helpdesk,registrar -c blue,green,magenta \"npm:dev:backend\" \"npm:dev:helpdesk\" \"npm:dev:registrar\"",
    "dev:backend": "dotnet run --project backend/HariKnowsBackend/HariKnowsBackend.csproj --launch-profile http",
    "dev:helpdesk": "npm run dev --prefix frontend_helpdesk",
    "dev:registrar": "npm run dev --prefix frontend_registrar",
    "generate:raw-prompt": "node scripts/generate-raw-prompt.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react-markdown": "^10.1.0"
  }
}
