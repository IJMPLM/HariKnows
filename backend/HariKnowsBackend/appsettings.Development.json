{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "GeminiApi": {
    "Model": "gemini-flash-lite-latest",
    "FallbackModels": [
      "gemini-2.0-flash",
      "gemini-flash-latest"
    ],
    "MinRequestIntervalMs": 1200,
    "EnableGoogleSearchTool": false,
    "ThinkingBudget": 0,
    "MaxRateLimitRetries": 2,
    "RetryBaseDelayMs": 1000,
    "RetryJitterMs": 500
  }
}
