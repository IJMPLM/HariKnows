{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "HariKnows",
    "Audience": "HariKnowsHelpdesk",
    "SigningKey": "change-this-dev-signing-key-to-a-very-long-random-secret-2026",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 7,
    "RequireSecureCookies": false
  },
  "RagAssistant": {
    "MaxHistoryTurns": 8,
    "MaxHistoryCharsPerTurn": 220,
    "MaxFaqCharsPerEntry": 360
  },
  "GeminiApi": {
    "Model": "gemini-flash-lite-latest",
    "FallbackModels": [
      "gemini-2.0-flash",
      "gemini-flash-latest"
    ],
    "MinRequestIntervalMs": 1200,
    "EnableGoogleSearchTool": false,
    "ThinkingBudget": 0,
    "MaxRateLimitRetries": 2,
    "RetryBaseDelayMs": 1000,
    "RetryJitterMs": 500
  }
}
